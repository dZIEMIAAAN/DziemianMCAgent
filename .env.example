# DziemianMCAgent - Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED: Anthropic (Claude API)
# ===========================================
ANTHROPIC_API_KEY=sk-ant-api...

# ===========================================
# REQUIRED: Notion Integration
# ===========================================
# Get from: https://www.notion.so/my-integrations
NOTION_API_KEY=secret_...

# Database ID - from the URL of your Notion database
# https://www.notion.so/yourworkspace/DATABASE_ID?v=...
NOTION_DATABASE_ID=

# Full URL to your Notion database (for Telegram links)
NOTION_DATABASE_URL=https://www.notion.so/yourworkspace/...

# ===========================================
# REQUIRED: Telegram Bot
# ===========================================
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABC-DEF...

# Your chat ID - send /start to @userinfobot to get it
TELEGRAM_CHAT_ID=

# ===========================================
# OPTIONAL: Apify (for X/TikTok scraping)
# ===========================================
# Get from: https://console.apify.com/account/integrations
APIFY_API_TOKEN=

# ===========================================
# APPLICATION SETTINGS
# ===========================================
# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Dry run mode - if true, won't send to Notion/Telegram
DRY_RUN=false

# How many hours back to search for content
LOOKBACK_HOURS=48

# Minimum views per hour to consider a video
MIN_VPH_THRESHOLD=100
